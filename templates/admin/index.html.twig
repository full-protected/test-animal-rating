{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.title'|trans }}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">{{ 'admin.title'|trans }}</h1>

        <table class="table table-bordered">
            <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>{{ 'admin.animal'|trans }}</th>
                <th>{{ 'admin.votes'|trans }}</th>
                <th>{{ 'admin.score'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for stat in stats %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td class="text-capitalize">{{ stat.animalName }}</td>
                    <td>{{ stat.count }}</td>
                    <td>{{ stat.avgScore|number_format(1) }}/100</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">{{ 'admin.empty'|trans }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
