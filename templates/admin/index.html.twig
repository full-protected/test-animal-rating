{% extends 'base.html.twig' %}

{% block title %}Statistiques des animaux{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Classement des animaux</h1>

        <table class="table table-bordered">
            <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Animal</th>
                <th>Nombre de votes</th>
                <th>Score moyen</th>
            </tr>
            </thead>
            <tbody>
            {% for stat in stats %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td class="text-capitalize">{{ stat.animalName }}</td>
                    <td>{{ stat.count }}</td>
                    <td>{{ stat.avgScore|number_format(1) }}/100</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Aucun animal enregistré pour le moment</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
